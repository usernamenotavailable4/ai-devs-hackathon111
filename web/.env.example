# Auto-injected if you add "Vercel Postgres" storage to this project in the
# Vercel dashboard (Storage tab -> Create Database -> Postgres). Leave blank
# locally and lib/db.ts falls back to an in-memory store for `next dev`.
POSTGRES_URL=

# Optional. Get this from https://console.groq.com (Groq Console).
# Blank = DEMO_MODE (deterministic mock agent output, no external calls).
GROQ_API_KEY=
GROQ_MODEL_FLASH=openai/gpt-oss-20b
GROQ_MODEL_PRO=openai/gpt-oss-120b

# Optional. Get this from studio.lyzr.ai: click your org name (top-left
# sidebar) -> "Account & API Key" -> copy the key.
# Blank = local dispatch-planning fallback (invoke every agent).
LYZR_API_KEY=
LYZR_API_BASE=https://agent-prod.studio.lyzr.ai
LYZR_ORCHESTRATOR_AGENT_ID=

# Demo auth placeholder for write endpoints (see docs/PRD.md for the
# production IAM/OAuth2 note). Change this before sharing a public URL.
API_GATEWAY_KEY=demo-key-change-me
# Must match API_GATEWAY_KEY above -- exposed to the browser so the
# dashboard can call the API. Prefix required by Next.js for client access.
NEXT_PUBLIC_API_GATEWAY_KEY=demo-key-change-me
