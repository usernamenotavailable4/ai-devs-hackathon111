# ---- LLM (Groq, used by the web/ Next.js app) ----
# OpenAI-compatible Chat Completions API. Get a key at console.groq.com.
GROQ_API_KEY=
GROQ_MODEL_FLASH=openai/gpt-oss-20b
GROQ_MODEL_PRO=openai/gpt-oss-120b

# ---- Lyzr ----
# Get this from studio.lyzr.ai: click your org name (top-left sidebar) ->
# "Account & API Key" -> copy the key.
LYZR_API_KEY=
LYZR_API_BASE=https://agent-prod.studio.lyzr.ai

# ---- Qdrant ----
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=fraud_case_memory

# ---- Postgres ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fraud_investigator
POSTGRES_USER=fraud_admin
POSTGRES_PASSWORD=changeme_local_dev

# ---- Pub/Sub emulator ----
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
PUBSUB_PROJECT_ID=fraud-investigator-local

# ---- Mock Sanctions API ----
SANCTIONS_API_URL=http://mock-sanctions-api:8010

# ---- Mode ----
# If GROQ_API_KEY / LYZR_API_KEY are empty, every service runs in
# deterministic MOCK mode so the full pipeline still runs end-to-end.
DEMO_MODE=true

# ---- API Gateway auth (demo placeholder; production = full IAM/OAuth2) ----
API_GATEWAY_KEY=demo-key-change-me

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=
